# =============================================================================
# Single source of truth for ignored paths. No nested .gitignore files —
# everything ignored or tracked is decided here.
# =============================================================================

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Virtual envs ----------------------------------------------------------
.venv/
venv/
env/
.python-version

# ---- Environment / secrets -------------------------------------------------
.env
.env.*
!.env.example

# ---- Frontend (Node / Vite / pnpm) -----------------------------------------
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
.pnpm-store/

# Frontend logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Editor / IDE ----------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.sw?

# ---- OS --------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---- Project runtime data --------------------------------------------------
# All app-generated artifacts live under STORAGE_PATH (default
# ./local_storage/, anchored to the repo root). Never tracked. The
# stray src/local_storage/ duplicate is the same intent — older test
# runs accidentally wrote there.
local_storage/
src/local_storage/

# ---- Test / smoke artifacts ------------------------------------------------
e2e_test_summary.json
output/                     # playwright screenshots / debug traces
.playwright-cli/            # playwright CLI per-cwd cache
playwright-cli.json         # local playwright skill config (browserName: chromium)

# ---- Vendored / WIP --------------------------------------------------------
# /projects holds upstream vendor code (LinearRAG paper, ARAG reference)
# that we keep around for diffing but don't ship.
/projects/

# ---- Input documents at repo root ------------------------------------------
# PDFs / Markdown that you drop in for ad-hoc testing — keep them out of
# the tracked tree even when they happen to live next to README.md.
/*.pdf

# ---- Repo housekeeping -----------------------------------------------------
.codex/                     # local codex CLI scratch
.claude/                    # local Claude Code scratch
docs/
.diag/