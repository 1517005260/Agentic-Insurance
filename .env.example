# =============================================================================
# agentic_rag environment template — copy to .env and fill in.
#
# Policy: every model call goes through an OpenAI-compatible HTTP endpoint.
# The only allowed local model is the spaCy NER pipeline (LinearRAG entity
# layer); no SentenceTransformer / transformers / torch.
# =============================================================================

# ---- PaddleOCR (layout-parsing jobs API on AI Studio) -----------------------
# Used by the ingestion layer to convert PDFs into page Markdown + images.
# API_URL is the async jobs base: the client POSTs here to submit and polls
# GET <API_URL>/<jobId> until the job is done.
API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
TOKEN=<your-aistudio-token>
# Optional: override the served layout-parsing model (default PaddleOCR-VL-1.6).
# PADDLE_OCR_MODEL=PaddleOCR-VL-1.6

# ---- VLM (vision-language model) --------------------------------------------
# Used by read.page when page_mode == text_with_img (table / chart / scan).
VLM_API_KEY=
VLM_API_BASE_URL=https://api.openai.com/v1
VLM_MODEL=

# ---- Chat model -------------------------------------------------------------
# Drives the agent loop (tool-calling).
CHAT_API_KEY=
CHAT_API_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=

# Optional: local Qwen3-8B served via vLLM behind the same OpenAI-compatible
# protocol. Drop-in replacement for the API CHAT_* above — just set the three
# CHAT_* env vars to the local server and the agent uses it unchanged.
#
# vLLM is NOT a pyproject dependency (its torchvision==0.26 collides with
# the base env's torchvision==0.25 pin; even as an opt-in extra it would
# make `uv sync` unsolvable — see pyproject.toml policy comment for the
# exact reason). Install vllm directly into an isolated venv:
#
#   1) isolated venv (vllm pulls its own torch + CUDA libs, ~7 GB):
#
#        uv venv .venv-local-llm --python 3.12
#        VIRTUAL_ENV=$(pwd)/.venv-local-llm uv pip install 'vllm>=0.21.0,<0.22'
#
#   2) fetch the weights (~16 GB into STORAGE_PATH/models/Qwen3-8B/):
#
#        uv run python download_models.py --local-llm
#
#   3) launch the server (holds GPU + port 8000):
#
#        VIRTUAL_ENV=$(pwd)/.venv-local-llm uv run python serve_local_llm.py
#
#   4) point .env at it (and restart any process that holds a chat client):
#
#        CHAT_API_BASE_URL=http://127.0.0.1:8000/v1
#        CHAT_MODEL=Qwen3-8B
#        CHAT_API_KEY=local-noauth

# ---- Text embedding model ---------------------------------------------------
# Used by semantic_search (text channel) and the LinearRAG entity store.
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=

# ---- Visual / page-image embedding model ------------------------------------
# Used by the vision_dense index. The client speaks DashScope's NATIVE
# multimodal-embedding API; the OpenAI-compatible /v1/embeddings path does
# NOT serve multimodal models (text-only there).
#
# IMPORTANT: this base URL ends in /api/v1 (NOT /compatible-mode/v1).
#
# Beijing region:   https://dashscope.aliyuncs.com/api/v1
# Singapore region: https://dashscope-intl.aliyuncs.com/api/v1
#
# Recommended models (independent per-image vectors):
#   qwen3-vl-embedding             — 2560-d default (configurable 256–2560)
#   tongyi-embedding-vision-plus   — 1152-d, ≤3 MB / image
#   tongyi-embedding-vision-flash  —  768-d, cheaper
#
# The API key here is your DashScope key (sk-...).
VISUAL_EMBEDDING_API_KEY=
VISUAL_EMBEDDING_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
VISUAL_EMBEDDING_MODEL=qwen3-vl-embedding

# ---- Reranker (local Qwen3-Reranker, GPU FP16) ------------------------------
# Used by both the query-time rerank step (src/rag/rerank.py) AND the alias-
# edge veto layer in ingest (src/ingestion/index/linear_rag/disambig.py).
#
# Weights are loaded from STORAGE_PATH/models/<basename of repo>; pre-fetch
# with `python download_models.py`. The local cross-encoder is true pairwise
# (no cross-request normalization), so the score is a stable absolute
# threshold — that is what makes the alias-edge veto layer possible.
RERANK_MODEL_ID=Qwen/Qwen3-Reranker-0.6B

# ---- GLiNER NER labels (LinearRAG entity layer) -----------------------------
# GLiNER NER entity labels (open-set, lowercase, comma-separated). Override for your domain.
GLINER_LABELS=person,organization,location,facility,product,event,creative work,law,group,concept,date,time,money,number
# Subset of GLINER_LABELS treated as noise sinks (spans tagged with these are dropped).
GLINER_NOISE_LABELS=date,time,money,number

# ---- Local storage root -----------------------------------------------------
STORAGE_PATH=./local_storage


# =============================================================================
# Web app (src/api/) — only needed when serving the FastAPI backend.
# Algorithm-only workflows can ignore everything below.
# =============================================================================

# ---- Tavily (web search for the regulation-lookup workbench) ----------------
# Free tier is sufficient for the demo; obtain a key at https://tavily.com/.
# When unset the regulation-search endpoint returns a 503 and the UI shows a
# disabled state; nothing else is affected.
TAVILY_API_KEY=
TAVILY_API_BASE_URL=https://api.tavily.com

# ---- API server -------------------------------------------------------------
# JWT signing — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=720

# Bootstrap admin (created on first startup if no users exist).
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# CORS origins for the Vite dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
